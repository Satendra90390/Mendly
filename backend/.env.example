# ============================================================
# Mendly Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# JWT — used for session tokens
JWT_SECRET=

# Token expiry in minutes (default: 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Supabase ─────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database — Supabase PostgreSQL connection string
# Find in: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.your-project:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres

# ─── CORS & Frontend ──────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_ORIGINS=http://localhost:5500
FRONTEND_URL=http://localhost:5500

# Backend URL (for OAuth callbacks) — leave empty to auto-detect
BACKEND_URL=

# Server port
PORT=8002

# ─── AI Provider ──────────────────────────────────────────
# "nvidia" or "gemini"
CHATBOT_PROVIDER=nvidia

# NVIDIA NIM configuration
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_MAX_RETRIES=2
NVIDIA_TIMEOUT=45

# Gemini (fallback)
GEMINI_API_KEY=

# ─── OAuth ────────────────────────────────────────────────
# Google OAuth2 — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
