# Copy this file to .env (or set these as environment variables in your
# hosting provider's dashboard — Render, Railway, etc.)

# A long, random, secret string used to sign JWTs. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret

# How long a login session stays valid, in minutes. Default: 7 days.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database connection string.
# Local development (default if unset): sqlite:///./mediguide.db
# Production (Postgres on Render/Railway): postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///./mediguide.db

# Comma-separated list of frontend origins allowed to call this API.
# Use "*" only for local development — lock this down in production.
# Example: https://mediguide.vercel.app,https://www.mediguide.app
FRONTEND_ORIGINS=*

# Frontend URL — used for OAuth redirects (Google, etc.)
# Local: http://localhost:5500
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5500

# Port the server listens on (Render/Railway set this automatically).
PORT=8002

# ── AI Provider ──────────────────────────────────────────────────────────────
# Set to "nvidia" (recommended) or "gemini".
CHATBOT_PROVIDER=nvidia

# ── NVIDIA NIM (Recommended — free 1000 credits at build.nvidia.com) ────────
# Get your key at: https://build.nvidia.com → Sign up → Pick any model → Copy API key
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_MAX_RETRIES=2
NVIDIA_TIMEOUT=45

# ── Google Gemini (Alternative) ──────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get your credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email (Gmail SMTP) — for OTP verification emails ─────────────────────────
# Gmail: enable 2FA → generate App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Mendly

# ── SMS (MSG91) — for phone OTP ─────────────────────────────────────────────
# Get your auth key at: https://msg91.com → Settings → Auth Key
MSG91_AUTH_KEY=your_auth_key_here
MSG91_TEMPLATE_ID=
