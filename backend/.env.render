# ============================================================
# Mendly Backend — Render Environment Variables
# Copy these to Render Dashboard → Environment tab
# ============================================================

# JWT — used for session tokens (set via Render dashboard)
JWT_SECRET=

# Token expiry in minutes (7 days = 10080)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── MongoDB Atlas (set via Render dashboard) ───────────────
MONGODB_URI=

# ─── CORS & Frontend ──────────────────────────────────────
FRONTEND_ORIGINS=https://mendly-xi.vercel.app
FRONTEND_URL=https://mendly-xi.vercel.app

# ─── AI Provider (set via Render dashboard) ────────────────
CHATBOT_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_MAX_RETRIES=2
NVIDIA_TIMEOUT=45

# ─── Server ───────────────────────────────────────────────
PORT=8002
BACKEND_URL=https://mendly-backend-0vyg.onrender.com
